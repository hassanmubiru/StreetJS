#!/usr/bin/env bash
# pre-push hook: blocks pushing a release tag (refs/tags/v*.*.*) whose version
# does not match streetjs / @streetjs/core / @streetjs/cli at the tagged commit.
# Prevents "phantom" tags that the publish workflow would reject after the fact.
#
# Enabled via core.hooksPath=.githooks (set by the repo `prepare` script).
# Bypass intentionally with `git push --no-verify`.
set -uo pipefail

status=0

# Defense-in-depth: refuse to push private-key material (see KEY-ROTATION-RUNBOOK).
# Catches *.pem/*.key/*.p12/*.pfx files and PEM private-key headers on their own
# line anywhere in tracked content. Bypass intentionally with `git push --no-verify`.
if git ls-files | grep -qE '\.(pem|key|p12|pfx)$'; then
  echo "[pre-push] BLOCKED: a private key / keystore file is tracked. Remove it and rotate the credential." >&2
  status=1
fi
if git grep -nI -E '^[[:space:]]*-----BEGIN ([A-Z]+ )*PRIVATE KEY-----[[:space:]]*$' -- . ':(exclude)**/*.test.*' >/dev/null 2>&1; then
  echo "[pre-push] BLOCKED: private key material detected in tracked content." >&2
  status=1
fi

# stdin: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$local_ref" in
    refs/tags/v[0-9]*.[0-9]*.[0-9]*)
      tag="${local_ref#refs/tags/}"
      # local_sha is the tag object; resolve to the commit it points to.
      commit="$(git rev-list -n1 "$tag" 2>/dev/null || echo "$local_sha")"
      echo "[pre-push] verifying release tag ${tag} → ${commit:0:12}"
      if ! node scripts/check-tag-version.mjs "$tag" "$commit"; then
        echo "[pre-push] BLOCKED: ${tag} version mismatch. Use --no-verify to override." >&2
        status=1
      fi
      ;;
  esac
done

exit "$status"
