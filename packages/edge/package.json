{
  "name": "@streetjs/edge",
  "version": "1.0.1",
  "description": "Edge Runtime adapter for the Street framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsc -p tsconfig.json && node --test dist/*.test.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "street",
    "edge",
    "runtime",
    "adapter",
    "cloudflare",
    "vercel"
  ],
  "license": "MIT",
  "author": "street contributors",
  "homepage": "https://hassanmubiru.github.io/StreetJS/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/StreetJS.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/StreetJS/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/tests/**",
    "!dist/**/__tests__/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "streetjs": "^1.0.9"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
