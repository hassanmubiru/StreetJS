{
  "name": "@streetjs/ratelimit",
  "version": "1.0.0",
  "description": "StreetJS rate limiting: sliding-window limiter middleware with global/per-IP/per-user scopes, a human-readable window parser, a @RateLimit method decorator, 429 + Retry-After/X-RateLimit-* headers, and pluggable in-memory or Redis backing stores.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/tests/**",
    "!dist/examples/**",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "c8": {
    "include": ["dist/**/*.js"],
    "exclude": ["dist/tests/**", "dist/examples/**"],
    "reporter": ["text", "lcov"],
    "all": true,
    "check-coverage": true,
    "lines": 90,
    "functions": 90,
    "branches": 88,
    "statements": 90
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "coverage": "c8 node --test dist/tests/*.test.js",
    "example": "node dist/examples/integration.js",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "streetjs",
    "street-framework",
    "rate-limit",
    "rate-limiting",
    "sliding-window",
    "middleware",
    "throttle",
    "redis",
    "typescript",
    "esm"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/StreetJS/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/StreetJS.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/StreetJS/issues"
  },
  "dependencies": {
    "@streetjs/context": "^1.1.0",
    "@streetjs/exceptions": "^1.0.0",
    "@streetjs/store": "^1.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
