{
  "name": "@streetjs/workflow",
  "version": "1.0.0",
  "description": "StreetJS Core v2 Pillar 5: a production-grade, strongly-typed, durable workflow orchestration engine that composes the realtime, queue, events, and storage pillars into reliable, multi-step, long-running workflows through an imperative, journaled, deterministic-replay execution model. Zero-dependency in-memory persistence by default, optional Redis persistence isolated behind a submodule, and optional structural pillar bridges with no hard pillar dependency.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./redis": {
      "import": "./dist/redis/index.js",
      "types": "./dist/redis/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "example": "npm run build && node dist/examples/order-processing/index.js",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "streetjs",
    "street-framework",
    "workflow",
    "orchestration",
    "durable-execution",
    "saga",
    "compensation",
    "retry",
    "event-sourcing",
    "deterministic-replay",
    "state-machine",
    "redis",
    "typescript",
    "esm"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/StreetJS/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/StreetJS.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/StreetJS/issues"
  },
  "dependencies": {
    "streetjs": "^1.0.25"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@streetjs/storage": ">=1.0.0",
    "@streetjs/queue": ">=1.0.0",
    "@streetjs/events": ">=1.0.0",
    "@streetjs/realtime": ">=1.0.0",
    "redis": "^4"
  },
  "peerDependenciesMeta": {
    "@streetjs/storage": {
      "optional": true
    },
    "@streetjs/queue": {
      "optional": true
    },
    "@streetjs/events": {
      "optional": true
    },
    "@streetjs/realtime": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
