{
  "name": "@streetjs/logging",
  "version": "1.0.0",
  "description": "StreetJS logging foundation: fast, structured, level-based logging with child loggers, bound context, pluggable transports (JSON/pretty/stream/memory/multi), automatic secret redaction, safe serialization of errors and circular structures, and timers. Zero runtime dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/tests/**",
    "!dist/examples/**",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "c8": {
    "include": ["dist/**/*.js"],
    "exclude": ["dist/tests/**", "dist/examples/**", "dist/types.js"],
    "reporter": ["text", "lcov"],
    "all": true,
    "check-coverage": true,
    "lines": 90,
    "functions": 90,
    "branches": 90,
    "statements": 90
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "coverage": "c8 node --test dist/tests/*.test.js",
    "example": "node dist/examples/integration.js",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "streetjs",
    "street-framework",
    "logging",
    "logger",
    "structured-logging",
    "json-logger",
    "log-levels",
    "child-logger",
    "redaction",
    "secrets",
    "observability",
    "typescript",
    "esm",
    "zero-dependencies"
  ],
  "author": "street contributors",
  "license": "MIT",
  "homepage": "https://hassanmubiru.github.io/StreetJS/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassanmubiru/StreetJS.git"
  },
  "bugs": {
    "url": "https://github.com/hassanmubiru/StreetJS/issues"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
